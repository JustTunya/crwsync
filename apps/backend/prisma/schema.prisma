generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [citext]
}

enum RoleEnum {
  MEMBER @map("member")
  ADMIN @map("admin")
  SUPER_ADMIN @map("super_admin")

  @@map("users_role_enum")
}

enum WorkspaceRoleEnum {
  OWNER  @map("owner")
  ADMIN  @map("admin")
  MEMBER @map("member")
  GUEST  @map("guest")

  @@map("workspace_role_enum")
}

enum UserStatus {
  ONLINE @map("online")
  BUSY   @map("busy")
  AWAY   @map("away")

  @@map("user_status_enum")
}

enum TaskPriorityEnum {
  NONE   @map("none")
  LOW    @map("low")
  MEDIUM @map("medium")
  HIGH   @map("high")
  URGENT @map("urgent")

  @@map("task_priority_enum")
}

enum ModuleTypeEnum {
  BOARD @map("board")
  CHAT  @map("chat")

  @@map("module_type_enum")
}

model User {
  id                   String     @id @default(uuid()) @db.Uuid
  email                String     @unique(map: "idx_user_email") @db.Citext
  username             String     @unique(map: "idx_user_username") @db.Citext
  firstname            String     @db.Text
  lastname             String     @db.Text
  birthdate            DateTime   @db.Date
  avatar_key           String?    @db.Text
  role                 RoleEnum   @default(MEMBER)
  role_version         Int        @default(1)
  status_preference    UserStatus @default(ONLINE)
  password_hash        String     @db.Text
  last_password_change DateTime?  @db.Timestamptz
  email_verified_at    DateTime?  @db.Timestamptz
  role_changed_at      DateTime   @default(now()) @db.Timestamptz
  last_login           DateTime?  @db.Timestamptz
  created_at           DateTime   @default(now()) @db.Timestamptz
  updated_at           DateTime   @updatedAt @db.Timestamptz

  sessions            Session[]
  email_verifications EmailVerification[]
  password_resets     PasswordReset[]
  ws_memberships      WorkspaceMember[]
  ws_sent_invites     WorkspaceInvite[] @relation("InvCreator")
  ws_received_invites WorkspaceInvite[] @relation("InvitedUser")
  boards_created      Board[]
  tasks_assigned      Task[]            @relation("TaskAssignee")
  tasks_created       Task[]            @relation("TaskCreator")
  chat_messages       ChatMessage[]

  @@map("users")
}

model Session {
  id                 String   @id @db.Uuid
  user_id            String   @db.Uuid
  user               User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  refresh_token_hash String   @db.Text
  persistent         Boolean  @default(false)
  created_at         DateTime @default(now()) @db.Timestamptz
  expires_at         DateTime? @db.Timestamptz
  revoked_at         DateTime? @db.Timestamptz
  ua                 String?  @db.Text
  ip                 String?  @db.Text

  @@index([user_id], map: "idx_session_user_id")
  @@map("sessions")
}

model EmailVerification {
  id         String   @id @default(uuid()) @db.Uuid
  email      String   @unique(map: "idx_verification_email") @db.Text
  user_id    String?  @db.Uuid
  user       User?    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  token_hash String   @unique(map: "idx_verification_token") @db.Text
  status     String   @default("pending") @db.Text
  created_at DateTime @default(now()) @db.Timestamptz
  expires_at DateTime? @db.Timestamptz
  verified_at DateTime? @db.Timestamptz

  @@index([user_id], map: "idx_verification_user_id")
  @@map("email_verifications")
}

model PasswordReset {
  id         String   @id @default(uuid()) @db.Uuid
  email      String   @unique(map: "idx_password_reset_email") @db.Text
  user_id    String?  @db.Uuid
  user       User?    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  token_hash String   @unique(map: "idx_password_reset_token") @db.Text
  status     String   @default("pending") @db.Text
  created_at DateTime @default(now()) @db.Timestamptz
  expires_at DateTime? @db.Timestamptz
  reset_at   DateTime? @db.Timestamptz

  @@index([user_id], map: "idx_password_reset_user_id")
  @@map("password_resets")
}

model Workspace {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.Text
  slug        String   @db.Citext
  logo_key    String?  @db.Text
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @updatedAt @db.Timestamptz

  members       WorkspaceMember[]
  invites       WorkspaceInvite[]
  boards        Board[]
  modules       WorkspaceModule[]
  chat_rooms    ChatRoom[]
  chat_messages ChatMessage[]

  @@unique([slug], map: "idx_workspace_slug_unique")
  @@index([slug], map: "idx_workspace_slug_index")
  @@map("workspaces")
}

model WorkspaceMember {
  id           String            @id @default(uuid()) @db.Uuid
  workspace_id String            @db.Uuid
  user_id      String            @db.Uuid
  role         WorkspaceRoleEnum @default(MEMBER)
  joined_at    DateTime          @default(now()) @db.Timestamptz

  workspace    Workspace         @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([workspace_id, user_id], map: "idx_workspace_member_unique")
  @@index([user_id], map: "idx_workspace_member_user_id")
  @@map("workspace_members")
}

model WorkspaceInvite {
  id           String            @id @default(uuid()) @db.Uuid
  invitee_id   String            @db.Uuid
  creator_id   String?           @db.Uuid
  workspace_id String            @db.Uuid
  role         WorkspaceRoleEnum @default(MEMBER)
  created_at   DateTime          @default(now()) @db.Timestamptz
  status       String            @default("pending") @db.Text

  invitee      User              @relation("InvitedUser", fields: [invitee_id], references: [id], onDelete: Cascade)
  creator      User?             @relation("InvCreator", fields: [creator_id], references: [id], onDelete: SetNull)
  workspace    Workspace         @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@unique([invitee_id, workspace_id], map: "idx_workspace_invite_unique")
  @@index([invitee_id], map: "idx_workspace_invite_invitee_id")
  @@index([creator_id], map: "idx_workspace_invite_creator_id")
  @@index([workspace_id], map: "idx_workspace_invite_workspace_id")
  @@map("workspace_invites")
}

model Board {
  id           String    @id @default(uuid()) @db.Uuid
  workspace_id String    @db.Uuid
  name         String    @db.Text
  description  String?   @db.Text
  created_by   String    @db.Uuid
  created_at   DateTime  @default(now()) @db.Timestamptz
  updated_at   DateTime  @updatedAt @db.Timestamptz

  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  creator      User      @relation(fields: [created_by], references: [id], onDelete: Cascade)
  columns      BoardColumn[]

  @@index([workspace_id], map: "idx_board_workspace_id")
  @@map("boards")
}

model BoardColumn {
  id         String   @id @default(uuid()) @db.Uuid
  board_id   String   @db.Uuid
  name       String   @db.Text
  position   Int      @default(0)
  color      String?  @db.Text
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  board      Board    @relation(fields: [board_id], references: [id], onDelete: Cascade)
  tasks      Task[]

  @@index([board_id], map: "idx_board_column_board_id")
  @@map("board_columns")
}

model Task {
  id          String           @id @default(uuid()) @db.Uuid
  column_id   String           @db.Uuid
  title       String           @db.Text
  description String?          @db.Text
  priority    TaskPriorityEnum @default(NONE)
  labels      String[]         @default([])
  tags        String[]         @default([])
  assignee_id String?          @db.Uuid
  due_date    DateTime?        @db.Timestamptz
  position    Int              @default(0)
  created_by  String           @db.Uuid
  created_at  DateTime         @default(now()) @db.Timestamptz
  updated_at  DateTime         @updatedAt @db.Timestamptz

  column      BoardColumn      @relation(fields: [column_id], references: [id], onDelete: Cascade)
  assignee    User?            @relation("TaskAssignee", fields: [assignee_id], references: [id], onDelete: SetNull)
  creator     User             @relation("TaskCreator", fields: [created_by], references: [id], onDelete: Cascade)

  @@index([column_id], map: "idx_task_column_id")
  @@index([assignee_id], map: "idx_task_assignee_id")
  @@map("tasks")
}

model WorkspaceModule {
  id           String         @id @default(uuid()) @db.Uuid
  workspace_id String         @db.Uuid
  type         ModuleTypeEnum
  reference_id String         @db.Uuid
  name         String         @db.Text
  position     Int            @default(0)
  created_at   DateTime       @default(now()) @db.Timestamptz

  workspace    Workspace      @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@unique([workspace_id, reference_id], map: "idx_workspace_module_unique")
  @@index([workspace_id], map: "idx_workspace_module_workspace_id")
  @@map("workspace_modules")
}

model ChatRoom {
  id           String        @id @default(uuid()) @db.Uuid
  workspace_id String        @db.Uuid
  name         String?       @db.Text
  created_at   DateTime      @default(now()) @db.Timestamptz
  updated_at   DateTime      @updatedAt @db.Timestamptz

  workspace    Workspace     @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  messages     ChatMessage[]

  @@index([workspace_id], map: "idx_chatroom_workspace_id")
  @@map("chat_rooms")
}

model ChatMessage {
  id           String   @id @default(uuid()) @db.Uuid
  workspace_id String   @db.Uuid
  room_id      String   @db.Uuid
  sender_id    String   @db.Uuid
  content      String   @db.Text
  created_at   DateTime @default(now()) @db.Timestamptz
  updated_at   DateTime @updatedAt @db.Timestamptz
  is_deleted   Boolean  @default(false)
  is_edited    Boolean  @default(false)
  is_pinned    Boolean  @default(false)
  reply_to     String?  @db.Uuid

  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  room         ChatRoom  @relation(fields: [room_id], references: [id], onDelete: Cascade)
  sender       User      @relation(fields: [sender_id], references: [id], onDelete: Cascade)

  @@index([room_id, created_at], map: "idx_chatmsg_room_created")
  @@index([workspace_id], map: "idx_chatmsg_workspace_id")
  @@map("chat_messages")
}