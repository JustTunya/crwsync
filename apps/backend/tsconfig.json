{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "rootDir": "../../",
    "outDir": "./dist",
    "baseUrl": "./",
    "paths": {
      "@crwsync/types": ["../../packages/types/src/index.ts"],
      "@crwsync/types/*": ["../../packages/types/dist/*"],
    },
  },
  "include": ["./src/**/*.ts", "../../packages/types/src/**/*.ts"],
  "exclude": ["node_modules", "dist", "test"],
}
